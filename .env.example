# Copy to .env or .env.local and fill in local values.
# Do not commit real secrets.

# External APIs
TOMTOM_API_KEY=replace-with-tomtom-api-key
OWM_API_KEY=replace-with-openweather-api-key
OPENWEATHER_API_KEY=replace-with-openweather-api-key
TOMTOM_POLL_INTERVAL_MINUTES=5
WEATHER_POLL_INTERVAL_MINUTES=15

# Kafka / Schema Registry
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRAFFIC_RAW=traffic.raw
KAFKA_TOPIC_WEATHER_RAW=weather.raw
KAFKA_TOPIC_NEWS_RAW=news.raw
KAFKA_TOPIC_EVENTS=news.raw
SCHEMA_REGISTRY_URL=

# Redis / Postgres
REDIS_URL=redis://localhost:6380/0
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=traffic_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# AWS S3 lakehouse (plan v4 target)
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_REGION=ap-southeast-1
S3_BUCKET=cognitive-traffic-lakehouse
S3_WAREHOUSE=s3a://cognitive-traffic-lakehouse/warehouse
S3_ENDPOINT=

# MinIO / S3-compatible local fallback
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_BRONZE=warehouse

# Neo4j AuraDB cloud (plan v4 target)
NEO4J_AUTH=neo4j/password
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# MLflow tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=cognitive-traffic-local-artifacts

# Airflow local defaults
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_FERNET_KEY=replace-with-generated-fernet-key

# Geocoding / NLP. Leave empty unless you run a local Nominatim service.
NOMINATIM_URL=
PHOBERT_CHECKPOINT=

# Local API / frontend
API_DATA_DIR=data
CTA_MODEL_DIR=results/cta_training_outputs_balanced_v3_latest
MODEL_DIR=results/cta_training_outputs_balanced_v3_latest
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
VITE_API_BASE_URL=http://localhost:8000
